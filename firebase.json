{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "firestore.rules",
      "**/.*",
      "**/node_modules/**",
      "*.py",
      "*.bat",
      "cartas-db.json",
      "revisar.txt"
    ],
    "rewrites": [
      { "source": "**", "destination": "/pokemon-deck-builder.html" }
    ]
  }
}
