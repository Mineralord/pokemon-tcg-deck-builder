rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Lista blanca de cuentas autorizadas.
    // IMPORTANTE: debe coincidir con ALLOWED en sync.js. Si añades usuarios,
    // edita ambos sitios y vuelve a desplegar las reglas (firebase deploy --only firestore:rules).
    function autorizado() {
      return request.auth != null
        && request.auth.token.email in ['pmmt99@gmail.com', 'elizabethrgj378@gmail.com'];
    }

    // Solo el dueño puede editar la colección física.
    function esDueno() {
      return request.auth != null
        && request.auth.token.email == 'pmmt99@gmail.com';
    }

    // Validación de la forma del documento de colección (evita escrituras arbitrarias).
    function docValido() {
      return request.resource.data.keys().hasOnly(['inventory', 'savedDecks', 'updatedAt'])
        && request.resource.data.inventory is list
        && request.resource.data.savedDecks is list;
    }

    // Cada usuario autorizado solo accede a su propio documento.
    // Esto garantiza la privacidad: nadie lee los mazos guardados de otro.
    match /colecciones/{uid} {
      allow read: if autorizado() && request.auth.uid == uid;
      allow write: if autorizado() && request.auth.uid == uid && docValido();
    }

    // Inventario compartido (solo lectura para los autorizados; solo el dueño lo escribe).
    // P2 ve la colección del dueño desde aquí, sin acceder a sus mazos privados.
    match /compartido/{docId} {
      allow read: if autorizado();
      allow write: if esDueno()
        && docId == 'coleccion'
        && request.resource.data.keys().hasOnly(['inventory', 'updatedAt'])
        && request.resource.data.inventory is list;
    }

    // Sala / Versus: presencia, reglas acordadas, marcador, moneda, timer y chat.
    // Solo datos NO sensibles (nunca listas de cartas). Ambos autorizados leen/escriben.
    match /sala/{docId} {
      allow read, write: if autorizado();
    }
  }
}
